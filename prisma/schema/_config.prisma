// _config.prisma — generator, datasource, enums

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

enum Role {
  SUPERADMIN
  ADMIN
  OPERATOR
  MANAGEMENT
}

enum PermissionLevel {
  CREATE
  VIEW
  EDIT
  DELETE
}

enum ActivityStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum FarmerGroupCategory {
  EX_PLASMA
  SWADAYA
}

enum FarmerGroupType {
  ASOSIASI
  KOPERASI
}

enum RspoCertStatus {
  CERTIFIED
  PLANNED
}

enum TrainingCategory {
  PAKET_1_BMP_PC_RSPO_NKT
  PAKET_2_MK
  PAKET_2_K3
  PAKET_3_4_GEDSI_FINANCIAL_LIVELIHOOD_BUSDEV
  OTHER
}

