// _config.prisma — generator, datasource, enums

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

enum Role {
  SUPERADMIN
  ADMIN
  OPERATOR
  MANAGEMENT
}

enum PermissionLevel {
  CREATE
  VIEW
  EDIT
  DELETE
}

enum ActivityStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum FarmerGroupCategory {
  EX_PLASMA
  SWADAYA
}
