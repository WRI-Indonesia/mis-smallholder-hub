// geography.prisma — Regional hierarchy models

model Province {
  id        String     @id @default(cuid())
  code      String     @unique // Kode wilayah pemerintah
  name      String
  districts District[]

  @@map("reg-province")
}

model District {
  id           String        @id @default(cuid())
  provinceId   String        @map("province_id")
  province     Province      @relation(fields: [provinceId], references: [id])
  code         String        @unique // Kode wilayah pemerintah
  name         String
  farmerGroups FarmerGroup[]

  @@map("reg-district")
}
