// agronomy.prisma — Production and maintenance activity models

model AgronomyProduction {
  id           String     @id @default(cuid())
  landParcelId String     @map("land_parcel_id")
  landParcel   LandParcel @relation(fields: [landParcelId], references: [id])
  date         DateTime
  yieldKg      Float      @map("yield_kg")

  @@map("tbl-agronomy-production")
}

model MaintenanceType {
  id           String                @id @default(cuid())
  code         String                @unique
  name         String
  desc         String?
  maintenances AgronomyMaintenance[]

  @@map("ref-maintenance-type")
}

model AgronomyMaintenance {
  id                String          @id @default(cuid())
  landParcelId      String          @map("land_parcel_id")
  landParcel        LandParcel      @relation(fields: [landParcelId], references: [id])
  maintenanceTypeId String          @map("ref_maintenance_type_id")
  maintenanceType   MaintenanceType @relation(fields: [maintenanceTypeId], references: [id])
  date              DateTime
  value             Float?
  note              String?

  @@map("tbl-agronomy-maintenance")
}
