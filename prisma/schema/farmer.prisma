// farmer.prisma — Farmer, Batch, Commodity, and LandParcel models

model Batch {
  id      String   @id @default(cuid())
  code    String   @unique
  name    String
  desc    String?
  farmers Farmer[]

  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by")
  createdByUser  User?    @relation("BatchCreatedBy", fields: [createdBy], references: [id])
  modifiedAt     DateTime @updatedAt @map("modified_at")
  modifiedBy     String?  @map("modified_by")
  modifiedByUser User?    @relation("BatchModifiedBy", fields: [modifiedBy], references: [id])

  @@map("ref-batch")
}

model Commodity {
  code    String       @id
  name    String
  desc    String?
  parcels LandParcel[]

  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by")
  createdByUser  User?    @relation("CommodityCreatedBy", fields: [createdBy], references: [id])
  modifiedAt     DateTime @updatedAt @map("modified_at")
  modifiedBy     String?  @map("modified_by")
  modifiedByUser User?    @relation("CommodityModifiedBy", fields: [modifiedBy], references: [id])

  @@map("ref-commodity")
}

model Farmer {
  id            String               @id @default(cuid())
  farmerGroupId String               @map("farmer_group_id")
  farmerGroup   FarmerGroup          @relation(fields: [farmerGroupId], references: [id])
  batchId       String?              @map("batch_id")
  batch         Batch?               @relation(fields: [batchId], references: [id])
  wriFarmerId   String?              @map("wri_farmer_id")
  uiFarmerId    String?              @map("ui_farmer_id")
  name          String
  nik           String               @unique @db.VarChar(16)
  gender        String
  birthdate     DateTime?
  status        String?
  parcels       LandParcel[]
  trainings     TrainingParticipant[]
  hseWorkers    HseWorker[]

  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by")
  createdByUser  User?    @relation("FarmerCreatedBy", fields: [createdBy], references: [id])
  modifiedAt     DateTime @updatedAt @map("modified_at")
  modifiedBy     String?  @map("modified_by")
  modifiedByUser User?    @relation("FarmerModifiedBy", fields: [modifiedBy], references: [id])

  @@map("tbl-farmer")
}

model LandParcel {
  id            String                @id @default(cuid())
  farmerId      String                @map("farmer_id")
  farmer        Farmer                @relation(fields: [farmerId], references: [id])
  commodityCode String?               @map("commodity_code")
  commodity     Commodity?            @relation(fields: [commodityCode], references: [code])
  wriParcelId   String?               @map("wri_land_parcel_id")
  parcelCode    String?               @map("parcel_code")
  revision      Int                   @default(0)
  polygon       Unsupported("geometry(Polygon, 4326)")?
  centerPoint   Unsupported("geometry(Point, 4326)")?
  polygonSizeHa Float?                @map("polygon_size_ha")
  legalId       String?               @map("legal_id")
  legalSizeHa   Float?                @map("legal_size_ha")
  status        String?
  productions   AgronomyProduction[]
  maintenances  AgronomyMaintenance[]

  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by")
  createdByUser  User?    @relation("LandParcelCreatedBy", fields: [createdBy], references: [id])
  modifiedAt     DateTime @updatedAt @map("modified_at")
  modifiedBy     String?  @map("modified_by")
  modifiedByUser User?    @relation("LandParcelModifiedBy", fields: [modifiedBy], references: [id])

  @@map("tbl-land-parcel")
}
