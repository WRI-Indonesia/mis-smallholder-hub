// land-parcel.prisma — Land Parcel model

model LandParcel {
  id            String      @id @default(cuid())
  farmerId      String      @map("farmer_id")
  farmer        Farmer      @relation(fields: [farmerId], references: [id])
  parcelId      String      @map("parcel_id") // Internal parcel ID (unique per farmer)
  blok          String?     @map("blok") // Blok kebun
  geometry      Json?       @map("geometry") // GeoJSON polygon
  area          Float?      @map("area") // Area in hectares
  landStatus    String?     @map("land_status") // e.g., "Owned", "Leased", "Shared"
  cropType      String?     @map("crop_type") // Komoditas, e.g., "Kelapa Sawit"
  species       String?     @map("species") // Species komoditas, e.g., "Elaeis guineensis"
  isPsr         Boolean     @default(false) @map("is_psr") // PSR = Peremajaan Sawit Rakyat (replanting → produksi 0 wajar)
  plantingYear  Int?        @map("planting_year")
  notes         String?     @map("notes")
  // Sub-kelompok interim (denormalisasi, TD-014): hierarki KT belum jadi tabel.
  // Per-lahan karena satu petani bisa punya lahan di KT/Gapoktan berbeda.
  subGroupLv1   String?     @map("sub_group_lv1") // Gapoktan
  subGroupLv2   String?     @map("sub_group_lv2") // Kelompok Tani
  revision      Int         @default(0) @map("revision")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  createdBy     String?     @map("created_by")
  modifiedAt    DateTime    @updatedAt @map("modified_at")
  modifiedBy    String?     @map("modified_by")
  productionRecords ProductionRecord[]

  @@index([farmerId])
  @@index([isActive])
  @@index([parcelId])
  @@map("tbl_land_parcel")
}
