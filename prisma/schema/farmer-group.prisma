// farmer-group.prisma — Farmer group models

model FarmerGroup {
  id           String              @id @default(cuid())
  districtId   String              @map("district_id")
  district     District            @relation(fields: [districtId], references: [id])
  code         String?
  abrv         String?
  abrv3id      String?             @map("abrv_3id") @db.VarChar(50)
  name         String
  category     FarmerGroupCategory @default(SWADAYA)
  groupType    FarmerGroupType?    @map("group_type")
  joinYear     Int?                @map("join_year")
  establishedYear Int?             @map("established_year")
  rspoCertYear    Int?             @map("rspo_cert_year")
  rspoCertStatus  RspoCertStatus?  @map("rspo_cert_status")
  ispoCertYear    Int?             @map("ispo_cert_year")
  ispoCertStatus  CertStatus?      @map("ispo_cert_status")
  sapMapAssuranceYear   Int?         @map("sap_map_assurance_year")
  sapMapAssuranceStatus CertStatus?  @map("sap_map_assurance_status")
  locationLat  Float?              @map("location_lat")
  locationLong Float?              @map("location_long")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  createdBy    String?             @map("created_by")
  modifiedAt   DateTime            @updatedAt @map("modified_at")
  modifiedBy   String?             @map("modified_by")

  // RBAC
  users UserFarmerGroup[]
  farmers Farmer[]
  activities TrainingActivity[]

  @@index([districtId])
  @@index([isActive])
  @@index([code])

  @@map("tbl_farmer_group")
}
