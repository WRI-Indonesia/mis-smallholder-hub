// farmer-group.prisma — Farmer group models

model FarmerGroup {
  id           String              @id @default(cuid())
  districtId   String              @map("district_id")
  district     District            @relation(fields: [districtId], references: [id])
  code         String?
  abrv         String?
  abrv3id      String?             @map("abrv_3id") @db.VarChar(50)
  name         String
  category     FarmerGroupCategory @default(SWADAYA)
  joinYear     Int?                @map("join_year")
  locationLat  Float?              @map("location_lat")
  locationLong Float?              @map("location_long")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  createdBy    String?             @map("created_by")
  modifiedAt   DateTime            @updatedAt @map("modified_at")
  modifiedBy   String?             @map("modified_by")

  // RBAC
  users UserFarmerGroup[]
  farmers Farmer[]
  activities TrainingActivity[]

  @@index([districtId])
  @@index([isActive])
  @@index([code])

  @@map("tbl_farmer_group")
}
