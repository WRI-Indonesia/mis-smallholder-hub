# Database
DATABASE_URL="postgresql://user:password@localhost:5432/smallholder_hub"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="super-secret-key"

# Object Storage (S3-compatible — is3.cloudhost.id)
S3_ENDPOINT="https://is3.cloudhost.id"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
S3_BUCKET_NAME="mis-dev"
NEXT_PUBLIC_S3_PUBLIC_URL="https://is3.cloudhost.id/mis-dev"
